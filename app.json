{
  "expo": {
    "name": "Idrissimart",
    "slug": "idrissimart-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/logo.png",
    "scheme": "idrissimart",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logos/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.idrissimart.app",
      "buildNumber": "1",
      "icon": "./assets/logos/logo.png",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to take photos for your ads.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload images for your ads.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show nearby ads and services."
      }
    },
    "android": {
      "package": "com.idrissimart.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logos/logo.png",
        "backgroundColor": "#4b315e"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/logos/mini-logo-dark-theme.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Idrissimart to access your camera to take photos for ads."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Idrissimart to use your location to show nearby ads."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "YOUR_PROJECT_ID_HERE"
      }
    },
    "owner": "your-expo-account-name"
  }
}
